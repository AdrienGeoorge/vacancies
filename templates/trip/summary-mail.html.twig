<style>
    body {
        background-color: #1a1a2e !important;
        font-size: 16px;
        font-family: "Raleway", Arial, sans-serif;
        margin: 0;
        padding: 0;
    }

    .mail-wrapper {
        width: 560px;
        margin: 0 auto;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    }

    .mail-head {
        background: linear-gradient(135deg, #0f9b8e 0%, #1ab394 30%, #f2c14b 100%);
        padding: 2.5em 2em 2em;
        text-align: center;
    }

    .mail-logo {
        width: 4.5em;
        border-radius: 12px;
    }

    .mail-head-tagline {
        color: #ffffff;
        font-size: 14px;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.9;
        text-align: center;
    }

    .mail-head-title {
        color: #ffffff;
        font-size: 20px;
        font-weight: bold;
        margin-top: 0.5em;
        text-align: center;
    }

    .mail-content {
        background-color: #ffffff;
    }

    .mail-content-inner {
        padding: 2.5em 2.5em 2em;
    }

    .mail-hello {
        font-size: 22px;
        font-weight: bold;
        color: #2d2d44;
    }

    .mail-text {
        font-size: 15px;
        color: #4a4a5a;
        line-height: 1.6;
    }

    .mail-trip-card {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef6f5 100%);
        border-left: 4px solid #0f9b8e;
        border-radius: 0 8px 8px 0;
        padding: 1.2em 1.5em;
    }

    .mail-trip-name {
        font-size: 18px;
        font-weight: bold;
        color: #2d2d44;
    }

    .mail-trip-destinations {
        font-size: 14px;
        color: #0f9b8e;
        margin-top: 0.3em;
    }

    .mail-trip-dates {
        font-size: 13px;
        color: #6b7280;
        margin-top: 0.3em;
    }

    .mail-stats-grid {
        background-color: #f8f9ff;
        border-radius: 8px;
        padding: 1.2em 1.5em;
    }

    .mail-stat-row {
        font-size: 15px;
        color: #4a4a5a;
        padding: 0.5em 0;
        border-bottom: 1px solid #eee;
    }

    .mail-stat-label {
        color: #6b7280;
        font-size: 13px;
    }

    .mail-stat-value {
        font-weight: bold;
        color: #2d2d44;
    }

    .mail-button-container {
        text-align: center;
        padding: 0.5em 0;
    }

    .mail-button {
        background: linear-gradient(135deg, #0f9b8e, #1ab394);
        border-radius: 50px;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        padding: 1em 2.5em;
        font-size: 16px;
        font-weight: bold;
        letter-spacing: 0.5px;
        display: inline-block;
    }

    .mail-signature {
        font-size: 15px;
        color: #4a4a5a;
    }

    .mail-divider {
        border: none;
        border-top: 1px solid #eee;
        margin: 0;
    }

    .mail-footer {
        background-color: #2d2d44;
        padding: 1.5em 2em;
        text-align: center;
    }

    .mail-footer-text {
        font-size: 12px;
        color: #9a9ab0;
        line-height: 1.6;
    }

    .mail-link {
        color: #1ab394;
        text-decoration: none;
        font-weight: bold;
    }
</style>

<table style="margin: 0 auto; width: 560px;" cellpadding="0" cellspacing="0">
    <tbody>
    <tr>
        <td height="40"></td>
    </tr>
    <tr>
        <td>
            <table class="mail-wrapper" cellpadding="0" cellspacing="0" style="width: 560px;">
                <tbody>
                <tr>
                    <td class="mail-head">
                        <table style="width: 100%;" cellpadding="0" cellspacing="0">
                            <tbody>
                            <tr>
                                <td style="text-align: center;">
                                    <a href="{{ domain }}/" target="_blank">
                                        <img src="{{ domain ~ '/images/logo.png' }}" class="mail-logo"
                                             alt="{{ app_name }}">
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td height="12"></td>
                            </tr>
                            <tr>
                                <td class="mail-head-tagline">Prévois tes voyages</td>
                            </tr>
                            <tr>
                                <td height="8"></td>
                            </tr>
                            <tr>
                                <td class="mail-head-title">&#127881; Votre voyage est terminé !</td>
                            </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td class="mail-content">
                        <table style="width: 100%;" cellpadding="0" cellspacing="0">
                            <tbody>
                            <tr>
                                <td class="mail-content-inner">
                                    <table style="width: 100%;" cellpadding="0" cellspacing="0">
                                        <tbody>
                                        <tr>
                                            <td class="mail-hello">Bonjour {{ user.firstname ?? user.username }} &#128075;</td>
                                        </tr>
                                        <tr>
                                            <td height="16"></td>
                                        </tr>
                                        <tr>
                                            <td class="mail-text">
                                                Votre voyage <b>{{ trip.name }}</b> est maintenant terminé. Merci de nous avoir fait confiance pour l'organiser ! Voici un résumé de votre aventure.
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="20"></td>
                                        </tr>

                                        {# Trip card #}
                                        <tr>
                                            <td>
                                                <table cellpadding="0" cellspacing="0" style="width:100%; overflow:hidden; border:1px solid #d1fae5;">
                                                    <tbody>
                                                    {# Header gradient #}
                                                    <tr>
                                                        <td style="background:linear-gradient(135deg,#0f9b8e,#1ab394); padding:12px 18px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="color:#ffffff; font-size:12px; opacity:0.9; letter-spacing:1px; text-transform:uppercase;">
                                                                        &#128197; Itinéraire
                                                                    </td>
                                                                    {% if trip.departureDate %}
                                                                        <td style="color:#ffffff; font-size:12px; text-align:right; opacity:0.9;">
                                                                            {{ trip.departureDate|fr_date(false) }}
                                                                            {% if trip.returnDate %}&nbsp;&rarr;&nbsp;{{ trip.returnDate|fr_date(false) }}{% endif %}
                                                                        </td>
                                                                    {% endif %}
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    {# Destinations #}
                                                    {% if trip.destinations is not empty %}
                                                        {% for destination in trip.destinations %}
                                                            <tr>
                                                                <td style="background:#ffffff; padding:12px 18px;{% if not loop.last %} border-bottom:1px solid #f0faf9;{% endif %}">
                                                                    <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                        <tbody><tr>
                                                                            <td style="vertical-align:middle;">
                                                                                <table cellpadding="0" cellspacing="0">
                                                                                    <tbody><tr>
                                                                                        <td style="vertical-align:middle; padding-right:10px;">
                                                                                            <div style="width:28px; height:28px; border-radius:50%; background:#eef6f5; text-align:center; line-height:28px; font-size:14px;">&#128205;</div>
                                                                                        </td>
                                                                                        <td style="vertical-align:middle;">
                                                                                            <div style="font-size:15px; font-weight:bold; color:#2d2d44;">{{ destination.country.name }}</div>
                                                                                            {% if destination.departureDate %}
                                                                                                <div style="font-size:12px; color:#6b7280; margin-top:2px;">
                                                                                                    {{ destination.departureDate|fr_date(false) }}
                                                                                                    {% if destination.returnDate %}&nbsp;&rarr;&nbsp;{{ destination.returnDate|fr_date(false) }}{% endif %}
                                                                                                </div>
                                                                                            {% endif %}
                                                                                        </td>
                                                                                    </tr></tbody>
                                                                                </table>
                                                                            </td>
                                                                            {% if not loop.last %}
                                                                                <td style="text-align:right; vertical-align:middle; color:#0f9b8e; font-size:18px;">&#8595;</td>
                                                                            {% endif %}
                                                                        </tr></tbody>
                                                                    </table>
                                                                </td>
                                                            </tr>
                                                        {% endfor %}
                                                    {% endif %}
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="24"></td>
                                        </tr>

                                        {# Activités réalisées #}
                                        {% if nbActivities > 0 %}
                                        <tr>
                                            <td style="padding-bottom:16px;">
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#eef6f5; border-left:3px solid #0f9b8e;">
                                                    <tbody>
                                                    <tr>
                                                        <td style="padding:12px 14px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="font-size:13px; color:#2d2d44;">
                                                                        <b>Activités réalisées</b>
                                                                        <span style="font-size:12px; color:#6b7280;">durant ce voyage</span>
                                                                    </td>
                                                                    <td style="text-align:right; white-space:nowrap;">
                                                                        <span style="font-size:20px; font-weight:bold; color:#0f9b8e;">{{ nbActivities }}</span>
                                                                    </td>
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        {% endif %}

                                        {# Budget par catégorie #}
                                        {% if budgetCategories is not empty %}
                                        <tr>
                                            <td style="font-size:13px; font-weight:bold; color:#2d2d44; text-transform:uppercase; letter-spacing:1px; padding-bottom:8px;">&#128176; Récap des dépenses</td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#f8f9ff; border:1px solid #e5e7eb;">
                                                    <tbody>
                                                    {% for cat in budgetCategories %}
                                                    <tr>
                                                        <td style="padding:10px 14px;{% if not loop.last %} border-bottom:1px solid #e5e7eb;{% endif %}">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="font-size:13px; color:#6b7280;">{{ cat.label }}</td>
                                                                    <td style="text-align:right; font-size:14px; font-weight:bold; color:#2d2d44;">{{ cat.amount }} €</td>
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    {% endfor %}
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        <tr><td height="12"></td></tr>
                                        {% endif %}

                                        {# Total par voyageur #}
                                        {% if totalPerPerson > 0 %}
                                        <tr>
                                            <td style="padding-bottom:16px;">
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#eef6f5; border-left:3px solid #0f9b8e;">
                                                    <tbody>
                                                    <tr>
                                                        <td style="padding:12px 14px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="font-size:13px; color:#2d2d44;">
                                                                        <b>Total par voyageur</b>
                                                                        {% if nbTravelers > 1 %}
                                                                        <span style="font-size:12px; color:#6b7280; display:block; margin-top:2px;">Réparti entre {{ nbTravelers }} voyageurs</span>
                                                                        {% endif %}
                                                                    </td>
                                                                    <td style="text-align:right; white-space:nowrap;">
                                                                        <span style="font-size:20px; font-weight:bold; color:#0f9b8e;">{{ totalPerPerson }} €</span>
                                                                        <span style="display:block; font-size:11px; color:#6b7280;">/ personne</span>
                                                                    </td>
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        {% endif %}
                                        <tr>
                                            <td height="24"></td>
                                        </tr>

                                        {# Share CTA #}
                                        {% if trip.storyToken %}
                                        <tr>
                                            <td class="mail-text" style="text-align: center;">
                                                Vous souhaitez partager vos souvenirs ? Votre voyage est accessible via un lien public.
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="16"></td>
                                        </tr>
                                        <tr>
                                            <td class="mail-button-container">
                                                <a href="{{ domain }}/share/{{ trip.storyToken }}" class="mail-button"
                                                   target="_blank">&#127760; Voir mon voyage</a>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="20"></td>
                                        </tr>
                                        {% endif %}

                                        <tr>
                                            <td>
                                                <hr class="mail-divider">
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="20"></td>
                                        </tr>
                                        <tr>
                                            <td class="mail-signature">
                                                À bientôt pour de nouvelles aventures ! &#127758;<br>
                                                L'équipe <b>{{ app_name }}</b>
                                            </td>
                                        </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td class="mail-footer">
                        <table style="width: 100%;" cellpadding="0" cellspacing="0">
                            <tbody>
                            <tr>
                                <td class="mail-footer-text">
                                    &copy; {{ 'now'|date('Y') }}
                                    <a href="{{ domain }}" target="_blank" class="mail-link">{{ app_name }}</a>
                                </td>
                            </tr>
                            <tr>
                                <td height="8"></td>
                            </tr>
                            <tr>
                                <td class="mail-footer-text">
                                    Pour gérer vos préférences de notifications, rendez-vous dans vos
                                    <a href="{{ domain }}/settings" target="_blank" class="mail-link">paramètres</a>.
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                </tbody>
            </table>
        </td>
    </tr>
    <tr>
        <td height="40"></td>
    </tr>
    </tbody>
</table>
