<style>
    body {
        background-color: #1a1a2e !important;
        font-size: 16px;
        font-family: "Raleway", Arial, sans-serif;
        margin: 0;
        padding: 0;
    }

    .mail-wrapper {
        width: 560px;
        margin: 0 auto;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    }

    .mail-head {
        background: linear-gradient(135deg, #0f9b8e 0%, #1ab394 30%, #f2c14b 100%);
        padding: 2.5em 2em 2em;
        text-align: center;
    }

    .mail-logo {
        width: 4.5em;
        border-radius: 12px;
    }

    .mail-head-tagline {
        color: #ffffff;
        font-size: 14px;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.9;
        text-align: center;
    }

    .mail-head-title {
        color: #ffffff;
        font-size: 20px;
        font-weight: bold;
        margin-top: 0.5em;
        text-align: center;
    }

    .mail-content {
        background-color: #ffffff;
    }

    .mail-content-inner {
        padding: 2.5em 2.5em 2em;
    }

    .mail-hello {
        font-size: 22px;
        font-weight: bold;
        color: #2d2d44;
    }

    .mail-text {
        font-size: 15px;
        color: #4a4a5a;
        line-height: 1.6;
    }

    .mail-trip-card {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef6f5 100%);
        border-left: 4px solid #0f9b8e;
        border-radius: 0 8px 8px 0;
        padding: 1.2em 1.5em;
    }

    .mail-trip-name {
        font-size: 18px;
        font-weight: bold;
        color: #2d2d44;
    }

    .mail-trip-destinations {
        font-size: 14px;
        color: #0f9b8e;
        margin-top: 0.3em;
    }

    .mail-trip-dates {
        font-size: 13px;
        color: #6b7280;
        margin-top: 0.3em;
    }

    .mail-stats-grid {
        background-color: #f8f9ff;
        border-radius: 8px;
        padding: 1.2em 1.5em;
    }

    .mail-stat-row {
        font-size: 15px;
        color: #4a4a5a;
        padding: 0.5em 0;
        border-bottom: 1px solid #eee;
    }

    .mail-stat-label {
        color: #6b7280;
        font-size: 13px;
    }

    .mail-stat-value {
        font-weight: bold;
        color: #2d2d44;
    }

    .mail-button-container {
        text-align: center;
        padding: 0.5em 0;
    }

    .mail-button {
        background: linear-gradient(135deg, #0f9b8e, #1ab394);
        border-radius: 50px;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        padding: 1em 2.5em;
        font-size: 16px;
        font-weight: bold;
        letter-spacing: 0.5px;
        display: inline-block;
    }

    .mail-signature {
        font-size: 15px;
        color: #4a4a5a;
    }

    .mail-divider {
        border: none;
        border-top: 1px solid #eee;
        margin: 0;
    }

    .mail-footer {
        background-color: #2d2d44;
        padding: 1.5em 2em;
        text-align: center;
    }

    .mail-footer-text {
        font-size: 12px;
        color: #9a9ab0;
        line-height: 1.6;
    }

    .mail-link {
        color: #1ab394;
        text-decoration: none;
        font-weight: bold;
    }
</style>

<table style="margin: 0 auto; width: 560px;" cellpadding="0" cellspacing="0">
    <tbody>
    <tr>
        <td height="40"></td>
    </tr>
    <tr>
        <td>
            <table class="mail-wrapper" cellpadding="0" cellspacing="0" style="width: 560px;">
                <tbody>
                <tr>
                    <td class="mail-head">
                        <table style="width: 100%;" cellpadding="0" cellspacing="0">
                            <tbody>
                            <tr>
                                <td style="text-align: center;">
                                    <a href="{{ domain }}/" target="_blank">
                                        <img src="{{ domain ~ '/images/logo.png' }}" class="mail-logo"
                                             alt="{{ app_name }}">
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td height="12"></td>
                            </tr>
                            <tr>
                                <td class="mail-head-tagline">{{ 'mail.tagline'|trans({}, 'messages', locale) }}</td>
                            </tr>
                            <tr>
                                <td height="8"></td>
                            </tr>
                            <tr>
                                <td class="mail-head-title">{{ 'mail.summary.title'|trans({}, 'messages', locale) }}</td>
                            </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td class="mail-content">
                        <table style="width: 100%;" cellpadding="0" cellspacing="0">
                            <tbody>
                            <tr>
                                <td class="mail-content-inner">
                                    <table style="width: 100%;" cellpadding="0" cellspacing="0">
                                        <tbody>
                                        <tr>
                                            <td class="mail-hello">{{ 'mail.greeting'|trans({'%name%': user.firstname ?? user.username}, 'messages', locale) }}</td>
                                        </tr>
                                        <tr>
                                            <td height="16"></td>
                                        </tr>
                                        <tr>
                                            <td class="mail-text">
                                                {{ 'mail.summary.intro'|trans({'%trip%': trip.name}, 'messages', locale)|raw }}
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="20"></td>
                                        </tr>

                                        {# Trip card #}
                                        <tr>
                                            <td>
                                                <table cellpadding="0" cellspacing="0" style="width:100%; overflow:hidden; border:1px solid #d1fae5;">
                                                    <tbody>
                                                    {# Header gradient #}
                                                    <tr>
                                                        <td style="background:linear-gradient(135deg,#0f9b8e,#1ab394); padding:12px 18px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="color:#ffffff; font-size:12px; opacity:0.9; letter-spacing:1px; text-transform:uppercase;">
                                                                        {{ 'mail.summary.itinerary'|trans({}, 'messages', locale) }}
                                                                    </td>
                                                                    {% if trip.departureDate %}
                                                                        <td style="color:#ffffff; font-size:12px; text-align:right; opacity:0.9;">
                                                                            {{ trip.departureDate|locale_date(false, locale) }}
                                                                            {% if trip.returnDate %}&nbsp;&rarr;&nbsp;{{ trip.returnDate|locale_date(false, locale) }}{% endif %}
                                                                        </td>
                                                                    {% endif %}
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    {# Destinations #}
                                                    {% if trip.destinations is not empty %}
                                                        {% for destination in trip.destinations %}
                                                            <tr>
                                                                <td style="background:#ffffff; padding:12px 18px;{% if not loop.last %} border-bottom:1px solid #f0faf9;{% endif %}">
                                                                    <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                        <tbody><tr>
                                                                            <td style="vertical-align:middle;">
                                                                                <table cellpadding="0" cellspacing="0">
                                                                                    <tbody><tr>
                                                                                        <td style="vertical-align:middle; padding-right:10px;">
                                                                                            <div style="width:28px; height:28px; border-radius:50%; background:#eef6f5; text-align:center; line-height:28px; font-size:14px;">&#128205;</div>
                                                                                        </td>
                                                                                        <td style="vertical-align:middle;">
                                                                                            <div style="font-size:15px; font-weight:bold; color:#2d2d44;">{{ destination.country.name }}</div>
                                                                                            {% if destination.departureDate %}
                                                                                                <div style="font-size:12px; color:#6b7280; margin-top:2px;">
                                                                                                    {{ destination.departureDate|locale_date(false, locale) }}
                                                                                                    {% if destination.returnDate %}&nbsp;&rarr;&nbsp;{{ destination.returnDate|locale_date(false, locale) }}{% endif %}
                                                                                                </div>
                                                                                            {% endif %}
                                                                                        </td>
                                                                                    </tr></tbody>
                                                                                </table>
                                                                            </td>
                                                                            {% if not loop.last %}
                                                                                <td style="text-align:right; vertical-align:middle; color:#0f9b8e; font-size:18px;">&#8595;</td>
                                                                            {% endif %}
                                                                        </tr></tbody>
                                                                    </table>
                                                                </td>
                                                            </tr>
                                                        {% endfor %}
                                                    {% endif %}
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="24"></td>
                                        </tr>

                                        {# Activités réalisées #}
                                        {% if nbActivities > 0 %}
                                        <tr>
                                            <td style="padding-bottom:16px;">
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#eef6f5; border-left:3px solid #0f9b8e;">
                                                    <tbody>
                                                    <tr>
                                                        <td style="padding:12px 14px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="font-size:13px; color:#2d2d44;">
                                                                        <b>{{ 'mail.summary.activities'|trans({}, 'messages', locale) }}</b>
                                                                        <span style="font-size:12px; color:#6b7280;">{{ 'mail.summary.activities_during'|trans({}, 'messages', locale) }}</span>
                                                                    </td>
                                                                    <td style="text-align:right; white-space:nowrap;">
                                                                        <span style="font-size:20px; font-weight:bold; color:#0f9b8e;">{{ nbActivities }}</span>
                                                                    </td>
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        {% endif %}

                                        {# Barre de progression budget total #}
                                        {% if plannedTotal is not null and budgetTotal is defined %}
                                        {% set pct = min(((budgetTotal / plannedTotal) * 100)|round, 100) %}
                                        {% set barColor = pct >= 100 ? '#ef4444' : (pct >= 80 ? '#f97316' : '#0f9b8e') %}
                                        {% set labelColor = pct >= 100 ? '#dc2626' : (pct >= 80 ? '#ea580c' : '#0f9b8e') %}
                                        <tr>
                                            <td style="padding-bottom:16px;">
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#f8f9ff; border:1px solid #e5e7eb;">
                                                    <tbody>
                                                    <tr>
                                                        <td style="padding:12px 14px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody>
                                                                <tr>
                                                                    <td style="font-size:13px; font-weight:bold; color:#2d2d44; padding-bottom:8px;">
                                                                        {{ 'mail.summary.budget_total'|trans({}, 'messages', locale) }}
                                                                    </td>
                                                                    <td style="text-align:right; font-size:13px; font-weight:bold; color:{{ labelColor }}; padding-bottom:8px;">
                                                                        {{ budgetTotal }} / {{ plannedTotal }} {{ trip.currency.symbol|default('€') }} ({{ pct }}%)
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2">
                                                                        <table cellpadding="0" cellspacing="0" style="width:100%; height:8px; background:#e5e7eb; border-radius:4px; overflow:hidden;">
                                                                            <tbody><tr>
                                                                                <td style="width:{{ pct }}%; background:{{ barColor }}; height:8px;"></td>
                                                                                {% if pct < 100 %}<td style="width:{{ 100 - pct }}%; height:8px;"></td>{% endif %}
                                                                            </tr></tbody>
                                                                        </table>
                                                                    </td>
                                                                </tr>
                                                                </tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        {% endif %}

                                        {# Budget par catégorie #}
                                        {% if budgetCategories is not empty %}
                                        <tr>
                                            <td style="font-size:13px; font-weight:bold; color:#2d2d44; text-transform:uppercase; letter-spacing:1px; padding-bottom:8px;">{{ 'mail.summary.expenses'|trans({}, 'messages', locale) }}</td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#f8f9ff; border:1px solid #e5e7eb;">
                                                    <tbody>
                                                    {% for cat in budgetCategories %}
                                                    <tr>
                                                        <td style="padding:10px 14px;{% if not loop.last %} border-bottom:1px solid #e5e7eb;{% endif %}">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="font-size:13px; color:#6b7280;">{{ cat.label }}</td>
                                                                    <td style="text-align:right; font-size:14px; font-weight:bold; color:#2d2d44;">
                                                                        {{ cat.amount }} {{ trip.currency.symbol|default('€') }}
                                                                        {% if cat.planned is not null %}
                                                                            <span style="font-size:11px; font-weight:normal; color:#9ca3af;">/ {{ cat.planned }} {{ trip.currency.symbol|default('€') }}</span>
                                                                        {% endif %}
                                                                    </td>
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    {% endfor %}
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        <tr><td height="12"></td></tr>
                                        {% endif %}

                                        {# Total par voyageur #}
                                        {% if totalPerPerson > 0 %}
                                        <tr>
                                            <td style="padding-bottom:16px;">
                                                <table cellpadding="0" cellspacing="0" style="width:100%; background:#eef6f5; border-left:3px solid #0f9b8e;">
                                                    <tbody>
                                                    <tr>
                                                        <td style="padding:12px 14px;">
                                                            <table cellpadding="0" cellspacing="0" style="width:100%;">
                                                                <tbody><tr>
                                                                    <td style="font-size:13px; color:#2d2d44;">
                                                                        <b>{{ 'mail.summary.total_per_traveler'|trans({}, 'messages', locale) }}</b>
                                                                        {% if nbTravelers > 1 %}
                                                                        <span style="font-size:12px; color:#6b7280; display:block; margin-top:2px;">{{ 'mail.summary.split_between'|trans({'%count%': nbTravelers}, 'messages', locale) }}</span>
                                                                        {% endif %}
                                                                    </td>
                                                                    <td style="text-align:right; white-space:nowrap;">
                                                                        <span style="font-size:20px; font-weight:bold; color:#0f9b8e;">{{ totalPerPerson }} {{ trip.currency.symbol|default('€') }}</span>
                                                                        <span style="display:block; font-size:11px; color:#6b7280;">{{ 'mail.summary.per_person'|trans({}, 'messages', locale) }}</span>
                                                                    </td>
                                                                </tr></tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                        {% endif %}
                                        <tr>
                                            <td height="24"></td>
                                        </tr>

                                        {# Share CTA #}
                                        {% if trip.shareToken %}
                                        <tr>
                                            <td class="mail-text" style="text-align: center;">
                                                {{ 'mail.summary.share_cta'|trans({}, 'messages', locale) }}
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="16"></td>
                                        </tr>
                                        <tr>
                                            <td class="mail-button-container">
                                                <a href="{{ domain }}/share/{{ trip.shareToken }}" class="mail-button"
                                                   target="_blank">{{ 'mail.summary.see_trip'|trans({}, 'messages', locale) }}</a>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="20"></td>
                                        </tr>
                                        {% endif %}

                                        <tr>
                                            <td>
                                                <hr class="mail-divider">
                                            </td>
                                        </tr>
                                        <tr>
                                            <td height="20"></td>
                                        </tr>
                                        <tr>
                                            <td class="mail-signature">
                                                {{ 'mail.summary.farewell'|trans({}, 'messages', locale) }}<br>
                                                {{ 'mail.team'|trans({}, 'messages', locale) }} <b>{{ app_name }}</b>
                                            </td>
                                        </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td class="mail-footer">
                        <table style="width: 100%;" cellpadding="0" cellspacing="0">
                            <tbody>
                            <tr>
                                <td class="mail-footer-text">
                                    &copy; {{ 'now'|date('Y') }}
                                    <a href="{{ domain }}" target="_blank" class="mail-link">{{ app_name }}</a>
                                </td>
                            </tr>
                            <tr>
                                <td height="8"></td>
                            </tr>
                            <tr>
                                <td class="mail-footer-text">
                                    {{ 'mail.footer.manage_prefs'|trans({}, 'messages', locale) }}
                                    <a href="{{ domain }}/settings" target="_blank" class="mail-link">{{ 'mail.footer.settings'|trans({}, 'messages', locale) }}</a>.
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                </tbody>
            </table>
        </td>
    </tr>
    <tr>
        <td height="40"></td>
    </tr>
    </tbody>
</table>
